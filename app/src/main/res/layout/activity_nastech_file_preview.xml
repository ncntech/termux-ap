<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/nastech_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/nastech_header_bg"
        android:paddingStart="14dp"
        android:paddingEnd="6dp">

        <TextView
            android:id="@+id/nastech_preview_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/nastech_text"
            android:textSize="13sp"
            android:singleLine="true" />

        <ImageButton
            android:id="@+id/nastech_preview_close"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="@null"
            android:contentDescription="Close"
            app:tint="@color/nastech_accent" />

    </LinearLayout>

    <WebView
        android:id="@+id/nastech_preview_webview"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
